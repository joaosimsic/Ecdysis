# Ecdysis kernel configuration (see PRD.md §5)
# Copy to `.env` and adjust. Loaded via dotenvy at kernel startup.

# Required: number of FSM kernels to spawn (§2.1)
ECDYSIS_INSTANCES=4

# Required: Mastodon instance host. `mastodon.social` is rejected at
# config validation (§2.1) — use a chaos-heavy instance.
ECDYSIS_FIREHOSE=pawoo.net

# Optional: per-task `cap` allocator ceiling in MiB (§3, M7)
ECDYSIS_RAM_CEILING_MIB=256

# Optional: output dir for gen_XXX.{rs,wasm} fossils (§7)
ECDYSIS_FOSSIL_DIR=./fossils

# Optional: Reaper wasmtime epoch tick interval in ms (§4.2)
ECDYSIS_EPOCH_TICK_MS=1000

# Optional: tracing-subscriber filter
RUST_LOG=info
